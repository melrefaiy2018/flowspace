# FlowSpace Environment Variables
# Copy this file to .env — most users don't need to set anything here.

# AI provider: configure via the Settings UI inside the app.
# Settings are saved to ~/.flowspace/.llm-settings.json automatically.

# Google auth is handled by the gws CLI after clicking "Sign in with Google".
# No GOOGLE_CLIENT_ID or GOOGLE_CLIENT_SECRET needed.

# Optional: override the default port (default: 3000)
# PORT=3000
